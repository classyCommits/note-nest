{
    "manifest_version": 3,
    "name": "QuickNotes Sidepanel",
    "version": "1.0",
    "description": "A feature-rich notepad in the browser side panel.",
    "permissions": [
      "storage",
      "sidePanel",
      "contextMenus",
      "tabs",
      "downloads"
    ],
    "icons": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "action": {
      "default_title": "Open QuickNotes"
    },
    "background": {
      "service_worker": "background/background.js"
    },
    "side_panel": {
      "default_path": "sidepanel/sidepanel.html"
    },
    "commands": {
      "new-note": {
        "suggested_key": {
          "default": "Alt+N",
          "mac": "Alt+N"
        },
        "description": "Create a new note"
      },
      "focus-search": {
        "suggested_key": {
          "default": "Alt+S",
          "mac": "Alt+S"
        },
        "description": "Search notes"
      }
    }
  }