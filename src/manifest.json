{
    "manifest_version": 3,
    "name": "NoteNest",
    "short_name": "NoteNest",
    "version": "1.1",
    "description": "A rich notepad in your browser side panel. Write notes, organize by folders, add tags, highlight text, and auto-save as you type.",
    "minimum_chrome_version": "114",
    "permissions": [
      "storage",
      "sidePanel",
      "tabs" 
    ],
    "icons": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "action": {
      "default_title": "Open NoteNest"
    },
    "background": {
      "service_worker": "background/background.js"
    },
    "side_panel": {
      "default_path": "sidepanel/sidepanel.html"
    },
    "commands": {
        "new-note": {
            "suggested_key": {
                "default": "Alt+N",
                "mac": "Ctrl+Shift+N"
            },
            "description": "Create a new note"
        },
        "focus-search": {
            "suggested_key": {
                "default": "Alt+S",
                "mac": "Ctrl+Shift+S"
            },
            "description": "Focus search"
        }
    }
  }